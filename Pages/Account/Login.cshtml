@page
@model MediSphere.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = "~/Pages/Shared/_AuthLayout.cshtml";
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="form-floating mb-3">
        <input asp-for="CredentialModel.Email" class="form-control" autocomplete="username" aria-required="true" />
        <label asp-for="CredentialModel.Email"></label>
        <span asp-validation-for="CredentialModel.Email" class="text-danger"></span>
    </div>
    <div class="form-floating mb-3">
        <input asp-for="CredentialModel.Password" class="form-control" aria-required="true" />
        <label asp-for="CredentialModel.Password"></label>
        <span asp-validation-for="CredentialModel.Password" class="text-danger"></span>
    </div>
    <div class="mb-3 form-check">
        <input type="checkbox" asp-for="CredentialModel.RememberMe" class="form-check-input" />
        <label class="form-check-label" asp-for="CredentialModel.RememberMe">Remember Me</label>
    </div>
    <p class="mb-3">
        <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
    </p>
    <button type="submit" class="btn btn-primary w-100 btn-lg">Log in</button>
</form>
