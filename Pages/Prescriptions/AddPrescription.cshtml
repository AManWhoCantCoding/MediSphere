@page
@model MediSphere.Pages.Prescriptions.AddPrescriptionModel
@{
    ViewData["Title"] = Localizer["AddPrescription_Title"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>@Localizer["AddPrescription_Title"]</h2>
    <p>@Localizer["AddPrescription_Subtitle"]</p>
</div>

<div class="ms-card ms-form-card">
    <form id="add-prescription-form">
        <div class="form-floating mb-3">
            <select id="patientId" class="form-control" required></select>
            <label>@Localizer["Patient"]</label>
        </div>
        <div class="form-floating mb-3">
            <input id="medicationName" class="form-control" required />
            <label>@Localizer["MedicationName"]</label>
        </div>
        <div class="form-floating mb-3">
            <input id="dosage" class="form-control" required />
            <label>@Localizer["Dosage"]</label>
        </div>
        <div class="form-check mb-3">
            <input id="paymentNeeded" class="form-check-input" type="checkbox" />
            <label class="form-check-label">@Localizer["PaymentNeeded"]</label>
        </div>
        <div class="form-floating mb-4">
            <textarea id="notes" class="form-control"></textarea>
            <label>@Localizer["Notes"]</label>
        </div>
        <button type="submit" class="btn btn-primary w-100">@Localizer["AddPrescription_Title"]</button>
    </form>
</div>

@section Scripts {
    <script src="~/js/prescriptions.js" asp-append-version="true"></script>
}
