@page
@model MediSphere.Pages.Prescriptions.UpdatePrescriptionModel
@{
    ViewData["Title"] = "Update Prescription";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>Update Prescription</h2>
    <p>Edit prescription details.</p>
</div>

<div class="ms-card ms-form-card">
    <form id="update-prescription-form">
        <input type="hidden" id="prescriptionId" value="@Model.PrescriptionId" />
        <div class="form-floating mb-3">
            <select id="patientId" class="form-control" required></select>
            <label>Patient</label>
        </div>
        <div class="form-floating mb-3">
            <input id="medicationName" class="form-control" required />
            <label>Medication Name</label>
        </div>
        <div class="form-floating mb-3">
            <input id="dosage" class="form-control" required />
            <label>Dosage</label>
        </div>
        <div class="form-check mb-3">
            <input id="paymentNeeded" class="form-check-input" type="checkbox" />
            <label class="form-check-label">Payment Needed</label>
        </div>
        <div class="form-floating mb-3">
            <textarea id="notes" class="form-control"></textarea>
            <label>Notes</label>
        </div>
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" id="delete-prescription-btn" class="btn btn-danger">Delete</button>
    </form>
</div>

@section Scripts {
    <script src="~/js/prescriptions.js" asp-append-version="true"></script>
}
