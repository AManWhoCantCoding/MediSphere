@page
@model MediSphere.Pages.Prescriptions.IndexModel
@{
    ViewData["Title"] = Localizer["Prescriptions_Title"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-toolbar">
    <div class="ms-page-header mb-0">
        <h2>@Localizer["Prescriptions_Title"]</h2>
        <p>@Localizer["Prescriptions_Subtitle"]</p>
    </div>
    <a asp-page="/Prescriptions/AddPrescription" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> @Localizer["AddPrescription_Title"]
    </a>
</div>

<div class="ms-card">
    <div class="ms-table-wrap">
        <table class="table ms-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>@Localizer["Patient"]</th>
                    <th>@Localizer["MedicationName"]</th>
                    <th>@Localizer["Dosage"]</th>
                    <th>@Localizer["PaymentNeeded"]</th>
                    <th>@Localizer["Notes"]</th>
                    <th>@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody id="prescriptions-table-body">
                <tr><td colspan="7" class="text-center text-muted py-4">@Localizer["LoadingPrescriptions"]</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/prescriptions.js" asp-append-version="true"></script>
}
