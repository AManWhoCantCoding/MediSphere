@page
@model MediSphere.Pages.Appointments.IndexModel
@{
    ViewData["Title"] = Localizer["Appointments_Title"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>@Localizer["Appointments_Title"]</h2>
    <p>@Localizer["Appointments_Subtitle"]</p>
</div>

<div class="ms-card">
    <div id="calendar"></div>
</div>

<div class="modal fade" id="appointment-add">
    <div class="modal-dialog">
        <form id="add-appointment-form">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">@Localizer["AddAppointment"]</h4>
                    <button type="button" id="closeBtn" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" name="topic" id="NewAppointment_Topic">
                        <label>@Localizer["Topic"]</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["PatientLabel"]</label>
                        <select name="patientId" id="NewAppointment_PatientId" class="form-control">
                            <option value="">@Localizer["SelectPatient"]</option>
                        </select>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">@Localizer["StartTime"]</label>
                        <div class="col-sm-9">
                            <input class="form-control datetimepicker" name="startTime" id="NewAppointment_StartTime">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">@Localizer["EndTime"]</label>
                        <div class="col-sm-9">
                            <input class="form-control datetimepicker" name="endTime" id="NewAppointment_EndTime">
                        </div>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea class="form-control" name="notes" id="NewAppointment_Notes"></textarea>
                        <label>@Localizer["Notes"]</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Status"]</label>
                        <select name="status" id="NewAppointment_Status" class="form-control">
                            <partial name="_AppointmentStatusOptionsPartial" />
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="maincloseBtn" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button>
                    <button type="submit" class="btn btn-success">@Localizer["AddAppointmentButton"]</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="appointment-edit">
    <div class="modal-dialog">
        <form id="edit-appointment-form">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">@Localizer["EditAppointment"]</h4>
                    <button type="button" id="closeSelectedBtn" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control" name="topic" id="SelectedAppointment_Topic">
                        <label>@Localizer["Topic"]</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["PatientLabel"]</label>
                        <select name="patientId" id="SelectedAppointment_PatientId" class="form-control"></select>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">@Localizer["StartTime"]</label>
                        <div class="col-sm-9">
                            <input class="form-control datetimepicker" name="startTime" id="SelectedAppointment_StartTime">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">@Localizer["EndTime"]</label>
                        <div class="col-sm-9">
                            <input class="form-control datetimepicker" name="endTime" id="SelectedAppointment_EndTime">
                        </div>
                    </div>
                    <div class="form-floating mb-3">
                        <textarea class="form-control" name="notes" id="SelectedAppointment_Notes"></textarea>
                        <label>@Localizer["Notes"]</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">@Localizer["Status"]</label>
                        <select name="status" id="SelectedAppointment_Status" class="form-control">
                            <partial name="_AppointmentStatusOptionsPartial" />
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" id="maincloseSelectedBtn" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button>
                    <button type="submit" class="btn btn-success">@Localizer["UpdateAppointmentButton"]</button>
                    <button type="button" id="delete-appointment-btn" class="btn btn-danger">@Localizer["DeleteAppointmentButton"]</button>
                </div>
            </div>
            <input type="hidden" id="SelectedAppointmentId" />
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/appointments.js" asp-append-version="true"></script>
}
