@using MediSphere.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<UserModel> SignInManager
@inject UserManager<UserModel> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/css/bootstrap-datetimepicker.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.10.2/fullcalendar.min.css">
    <link rel="stylesheet" href="~/css/siteTheme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/resources/main-logo.svg">
</head>
<body>
    <div class="ms-app">
        <aside class="ms-sidebar">
            <a class="ms-sidebar-brand" asp-page="/Home/Dashboard">
                <img src="~/resources/logo.png" alt="MediSphere">
                <span>MediSphere</span>
            </a>
            <partial name="_SideMenuPartial" />
        </aside>

        <div id="sidebarOverlay" class="ms-overlay"></div>

        <div class="ms-main">
            <header class="ms-topbar">
                <div class="d-flex align-items-center gap-3">
                    <button type="button" id="sidebarToggle" class="ms-sidebar-toggle" aria-label="Toggle menu">
                        <i class="bi bi-list"></i>
                    </button>
                    <h1 class="ms-topbar-title">@ViewData["Title"]</h1>
                </div>
                <div class="ms-topbar-actions">
                    <partial name="_LoginPartial" />
                </div>
            </header>
            <main class="ms-content" role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/api-client.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.10.2/fullcalendar.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/3.10.2/locale-all.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datetimepicker/4.17.47/js/bootstrap-datetimepicker.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
