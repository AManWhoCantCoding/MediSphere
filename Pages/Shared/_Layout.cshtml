@using MediSphere.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<UserModel> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/siteTheme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/resources/main-logo.svg">
</head>
<body>
    <nav class="ms-public-nav">
        <a class="ms-public-brand" asp-page="/Index">
            <img src="~/resources/logo.png" alt="MediSphere">
            MediSphere
        </a>
        <partial name="_LoginPartial" />
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="ms-public-footer">
        &copy; @DateTime.Now.Year MediSphere — Hospital Management System
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
