@using MediSphere.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<UserModel> SignInManager

<nav class="ms-sidebar-nav">
    <a class="ms-nav-link" data-page href="/Home/Dashboard">
        <i class="bi bi-grid-1x2"></i>
        @Localizer["Nav_Dashboard"]
    </a>

    <a class="ms-nav-link" data-page href="/Patient">
        <i class="bi bi-person"></i>
        @Localizer["Nav_Patients"]
    </a>
    <ul class="ms-nav-sub">
        <li>
            <a class="ms-nav-link" data-page href="/Patient/AddPatient">
                <i class="bi bi-person-plus"></i>
                @Localizer["Nav_AddPatient"]
            </a>
        </li>
    </ul>

    <a class="ms-nav-link" data-page href="/Appointments">
        <i class="bi bi-calendar-event"></i>
        @Localizer["Nav_Appointments"]
    </a>

    <a class="ms-nav-link" data-page href="/Prescriptions">
        <i class="bi bi-capsule"></i>
        @Localizer["Nav_Prescriptions"]
    </a>
    <ul class="ms-nav-sub">
        <li>
            <a class="ms-nav-link" data-page href="/Prescriptions/AddPrescription">
                <i class="bi bi-plus-circle"></i>
                @Localizer["Nav_AddPrescription"]
            </a>
        </li>
    </ul>

    <a class="ms-nav-link" data-page href="/Reports">
        <i class="bi bi-file-earmark-medical"></i>
        @Localizer["Nav_Reports"]
    </a>
    <ul class="ms-nav-sub">
        <li>
            <a class="ms-nav-link" data-page href="/Reports/ReportTypes">
                <i class="bi bi-tags"></i>
                @Localizer["Nav_ReportTypes"]
            </a>
        </li>
        <li>
            <a class="ms-nav-link" data-page href="/Reports/ReportGenerator">
                <i class="bi bi-file-earmark-plus"></i>
                @Localizer["Nav_GenerateReport"]
            </a>
        </li>
    </ul>

    @if (User.IsInRole("Administrator"))
    {
        <a class="ms-nav-link" data-page href="/Administrator/Settings">
            <i class="bi bi-gear"></i>
            @Localizer["Nav_AdminSettings"]
        </a>
    }
</nav>
