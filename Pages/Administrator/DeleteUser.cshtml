@page
@model MediSphere.Pages.Administrator.DeleteUserModel
@{
    ViewData["Title"] = Localizer["DeleteUser"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}
<h1>@Localizer["DeleteUser"]</h1>

<p>@Localizer["DeleteUserConfirm"]</p>

<form method="post">
    <input type="hidden" asp-for="ExistingUserModel.Id" />
    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
    <a asp-page="/Administrator/Settings" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>
