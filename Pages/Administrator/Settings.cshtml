@page
@model MediSphere.Pages.Administrator.SettingsModel
@{
    ViewData["Title"] = "Administrator Settings";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>Administrator Settings</h2>
    <p>Manage staff accounts and system users.</p>
</div>

<div class="ms-toolbar mb-3">
    <a asp-page="/Administrator/Register" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Register a new user
    </a>
</div>

<div class="ms-card" id="general">
    <h3 style="font-size:1rem;font-weight:600;margin-bottom:16px;">User Settings</h3>
    <form class="ms-search" onsubmit="return false;">
        <input id="searchBox" class="form-control" type="search" placeholder="Search users...">
        <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
    </form>
    <div class="ms-table-wrap">
        <table class="table ms-table">
            <thead>
                <tr>
                    <th>First Name</th>
                    <th>Middle Name</th>
                    <th>Last Name</th>
                    <th>Email Address</th>
                    <th>Date of Birth</th>
                    <th>Contact Number</th>
                    <th>Gender</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users != null)
                {
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FirstName</td>
                            <td>@user.MiddleName</td>
                            <td>@user.LastName</td>
                            <td>@user.UserName</td>
                            <td>@user.DateOfBirth</td>
                            <td class="contact-number">@user.PhoneNumber</td>
                            <td>@user.Gender</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-page="/Administrator/UpdateUser" asp-route-id="@user.Id" class="btn btn-primary btn-icon" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-page="/Administrator/LockoutUser" asp-route-id="@user.Id" class="btn btn-secondary btn-icon" title="Lockout User">
                                        <i class="bi bi-lock"></i>
                                    </a>
                                    <a asp-page="/Administrator/DeleteUser" asp-route-id="@user.Id" class="btn btn-danger btn-icon" title="Delete">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/search.js"></script>
}
