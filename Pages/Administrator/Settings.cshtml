@page
@model MediSphere.Pages.Administrator.SettingsModel
@{
    ViewData["Title"] = Localizer["AdminSettings_Title"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>@Localizer["AdminSettings_Title"]</h2>
    <p>@Localizer["AdminSettings_Subtitle"]</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="ms-toolbar mb-3">
    <a asp-page="/Administrator/Register" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> @Localizer["RegisterNewUser"]
    </a>
</div>

<div class="ms-card" id="general">
    <h3 style="font-size:1rem;font-weight:600;margin-bottom:16px;">@Localizer["UserSettings"]</h3>
    <form class="ms-search" onsubmit="return false;">
        <input id="searchBox" class="form-control" type="search" placeholder="@Localizer["SearchUsersPlaceholder"]">
        <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
    </form>
    <div class="ms-table-wrap">
        <table class="table ms-table">
            <thead>
                <tr>
                    <th>@Localizer["FirstName"]</th>
                    <th>@Localizer["MiddleName"]</th>
                    <th>@Localizer["LastName"]</th>
                    <th>@Localizer["EmailAddress"]</th>
                    <th>@Localizer["DateOfBirth"]</th>
                    <th>@Localizer["ContactNumber"]</th>
                    <th>@Localizer["Gender"]</th>
                    <th>@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Users != null)
                {
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FirstName</td>
                            <td>@user.MiddleName</td>
                            <td>@user.LastName</td>
                            <td>@user.UserName</td>
                            <td>@user.DateOfBirth</td>
                            <td class="contact-number">@user.PhoneNumber</td>
                            <td>@user.Gender</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-page="/Administrator/UpdateUser" asp-route-id="@user.Id" class="btn btn-primary btn-icon" title="@Localizer["Edit"]">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-page="/Administrator/LockoutUser" asp-route-id="@user.Id" class="btn btn-secondary btn-icon" title="@Localizer["LockoutUser"]">
                                        <i class="bi bi-lock"></i>
                                    </a>
                                    <a asp-page="/Administrator/DeleteUser" asp-route-id="@user.Id" class="btn btn-danger btn-icon" title="@Localizer["Delete"]">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/search.js"></script>
}
