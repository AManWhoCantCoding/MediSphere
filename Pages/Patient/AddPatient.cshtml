@page
@model MediSphere.Pages.Patient.AddPatientModel
@{
    ViewData["Title"] = "Add A Patient";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>Add A Patient</h2>
    <p>Register a new patient in the system.</p>
</div>

<div class="ms-card ms-form-card">
    <form id="add-patient-form">
        <div id="form-errors" class="text-danger mb-3"></div>
        <div class="form-floating mb-3">
            <input id="firstName" class="form-control" required />
            <label>First name</label>
        </div>
        <div class="form-floating mb-3">
            <input id="lastName" class="form-control" required />
            <label>Last name</label>
        </div>
        <div class="form-floating mb-3">
            <input id="emailAddress" class="form-control" type="email" />
            <label>Email Address</label>
        </div>
        <div class="form-floating mb-3">
            <input id="contactNumber" class="form-control" />
            <label>Phone Number</label>
        </div>
        <div class="form-floating mb-3">
            <select id="gender" class="form-control">
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Non-Binary">Non-Binary</option>
                <option value="Prefer not to say">Prefer not to say</option>
                <option value="Custom">Custom</option>
            </select>
            <label>Select gender</label>
        </div>
        <div class="form-floating mb-3">
            <input id="dateOfBirth" type="date" class="form-control" />
            <label>Date of Birth</label>
        </div>
        <div class="form-check mb-4">
            <input id="isPrivatePatient" class="form-check-input" type="checkbox" />
            <label class="form-check-label">Is not using state healthcare options?</label>
        </div>
        <button type="submit" class="btn btn-primary w-100">Add Patient</button>
    </form>
</div>

@section Scripts {
    <script src="~/js/patients.js" asp-append-version="true"></script>
}
