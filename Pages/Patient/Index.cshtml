@page
@model MediSphere.Pages.Patient.IndexModel
@{
    ViewData["Title"] = Localizer["Patients_Title"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>@Localizer["Patients_Title"]</h2>
    <p>@Localizer["Patients_Subtitle"]</p>
</div>

<div class="ms-card">
    <form class="ms-search" onsubmit="return false;">
        <input id="searchBox" class="form-control" type="search" placeholder="@Localizer["Patients_SearchPlaceholder"]">
        <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
    </form>
    <div class="ms-table-wrap">
        <table class="table ms-table">
            <thead>
                <tr>
                    <th>@Localizer["PatientId"]</th>
                    <th>@Localizer["FirstName"]</th>
                    <th>@Localizer["LastName"]</th>
                    <th>@Localizer["EmailAddress"]</th>
                    <th>@Localizer["ContactNumber"]</th>
                    <th>@Localizer["Gender"]</th>
                    <th>@Localizer["DateOfBirth"]</th>
                    <th>@Localizer["TreatmentType"]</th>
                    <th>@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody id="patients-table-body">
                <tr><td colspan="9" class="text-center text-muted py-4">@Localizer["LoadingPatients"]</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/patients.js" asp-append-version="true"></script>
}
