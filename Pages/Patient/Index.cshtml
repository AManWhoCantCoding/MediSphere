@page
@model MediSphere.Pages.Patient.IndexModel
@{
    ViewData["Title"] = "Patients";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>Patients</h2>
    <p>Search and manage patient records.</p>
</div>

<div class="ms-card">
    <form class="ms-search" onsubmit="return false;">
        <input id="searchBox" class="form-control" type="search" placeholder="Search patients...">
        <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
    </form>
    <div class="ms-table-wrap">
        <table class="table ms-table">
            <thead>
                <tr>
                    <th>Patient ID</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email Address</th>
                    <th>Contact Number</th>
                    <th>Gender</th>
                    <th>Date Of Birth</th>
                    <th>Treatment Type</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="patients-table-body">
                <tr><td colspan="9" class="text-center text-muted py-4">Loading patients via API...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/patients.js" asp-append-version="true"></script>
}
