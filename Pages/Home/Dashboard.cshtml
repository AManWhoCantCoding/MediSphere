
@page
@model MediSphere.Pages.Home.DashboardModel
@{
    ViewData["Title"] = Localizer["Dashboard_Title"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h1>@Localizer["Dashboard_Welcome"]</h1>
    <p>@Localizer["Dashboard_Overview"]</p>
</div>

<div class="ms-stat-grid" style="margin-bottom: 1.5rem;">
    <div class="ms-stat-card">
        <div class="ms-stat-icon teal"><i class="bi bi-people"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Total"]</div>
            <div class="ms-stat-title">@string.Format(Localizer["Dashboard_PatientsCount"].Value, Model.Stats.PatientCount)</div>
        </div>
    </div>
    <div class="ms-stat-card">
        <div class="ms-stat-icon indigo"><i class="bi bi-calendar-check"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Scheduled"]</div>
            <div class="ms-stat-title">@string.Format(Localizer["Dashboard_AppointmentsCount"].Value, Model.Stats.AppointmentCount)</div>
        </div>
    </div>
    <div class="ms-stat-card">
        <div class="ms-stat-icon amber"><i class="bi bi-capsule-pill"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Active"]</div>
            <div class="ms-stat-title">@string.Format(Localizer["Dashboard_PrescriptionsCount"].Value, Model.Stats.PrescriptionCount)</div>
        </div>
    </div>
    <div class="ms-stat-card">
        <div class="ms-stat-icon rose"><i class="bi bi-file-earmark-text"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Records"]</div>
            <div class="ms-stat-title">@string.Format(Localizer["Dashboard_ReportsCount"].Value, Model.Stats.ReportCount)</div>
        </div>
    </div>
</div>

<div class="ms-stat-grid">
    <a class="ms-stat-card" asp-page="/Patient/Index">
        <div class="ms-stat-icon teal"><i class="bi bi-person"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Module"]</div>
            <div class="ms-stat-title">@Localizer["Nav_Patients"]</div>
        </div>
    </a>
    <a class="ms-stat-card" asp-page="/Appointments/Index">
        <div class="ms-stat-icon indigo"><i class="bi bi-calendar-event"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Module"]</div>
            <div class="ms-stat-title">@Localizer["Nav_Appointments"]</div>
        </div>
    </a>
    <a class="ms-stat-card" asp-page="/Prescriptions/Index">
        <div class="ms-stat-icon amber"><i class="bi bi-capsule"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Module"]</div>
            <div class="ms-stat-title">@Localizer["Nav_Prescriptions"]</div>
        </div>
    </a>
    <a class="ms-stat-card" asp-page="/Reports/Index">
        <div class="ms-stat-icon rose"><i class="bi bi-file-earmark-medical"></i></div>
        <div>
            <div class="ms-stat-label">@Localizer["Module"]</div>
            <div class="ms-stat-title">@Localizer["Nav_Reports"]</div>
        </div>
    </a>
</div>

<div class="ms-card">
    <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">@Localizer["Dashboard_QuickStart"]</h3>
    <p class="text-muted mb-0" style="font-size:0.92rem;">
        @Localizer["Dashboard_QuickStartText"]
    </p>
</div>
