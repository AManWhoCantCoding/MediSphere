
@page
@model MediSphere.Pages.Home.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h1>Welcome to MediSphere</h1>
    <p>Hospital overview — select a module below or use the sidebar.</p>
</div>

<div class="ms-stat-grid" style="margin-bottom: 1.5rem;">
    <div class="ms-stat-card">
        <div class="ms-stat-icon teal"><i class="bi bi-people"></i></div>
        <div>
            <div class="ms-stat-label">Total</div>
            <div class="ms-stat-title">@Model.Stats.PatientCount Patients</div>
        </div>
    </div>
    <div class="ms-stat-card">
        <div class="ms-stat-icon indigo"><i class="bi bi-calendar-check"></i></div>
        <div>
            <div class="ms-stat-label">Scheduled</div>
            <div class="ms-stat-title">@Model.Stats.AppointmentCount Appointments</div>
        </div>
    </div>
    <div class="ms-stat-card">
        <div class="ms-stat-icon amber"><i class="bi bi-capsule-pill"></i></div>
        <div>
            <div class="ms-stat-label">Active</div>
            <div class="ms-stat-title">@Model.Stats.PrescriptionCount Prescriptions</div>
        </div>
    </div>
    <div class="ms-stat-card">
        <div class="ms-stat-icon rose"><i class="bi bi-file-earmark-text"></i></div>
        <div>
            <div class="ms-stat-label">Records</div>
            <div class="ms-stat-title">@Model.Stats.ReportCount Reports</div>
        </div>
    </div>
</div>

<div class="ms-stat-grid">
    <a class="ms-stat-card" asp-page="/Patient/Index">
        <div class="ms-stat-icon teal"><i class="bi bi-person"></i></div>
        <div>
            <div class="ms-stat-label">Module</div>
            <div class="ms-stat-title">Patients</div>
        </div>
    </a>
    <a class="ms-stat-card" asp-page="/Appointments/Index">
        <div class="ms-stat-icon indigo"><i class="bi bi-calendar-event"></i></div>
        <div>
            <div class="ms-stat-label">Module</div>
            <div class="ms-stat-title">Appointments</div>
        </div>
    </a>
    <a class="ms-stat-card" asp-page="/Prescriptions/Index">
        <div class="ms-stat-icon amber"><i class="bi bi-capsule"></i></div>
        <div>
            <div class="ms-stat-label">Module</div>
            <div class="ms-stat-title">Prescriptions</div>
        </div>
    </a>
    <a class="ms-stat-card" asp-page="/Reports/Index">
        <div class="ms-stat-icon rose"><i class="bi bi-file-earmark-medical"></i></div>
        <div>
            <div class="ms-stat-label">Module</div>
            <div class="ms-stat-title">Reports</div>
        </div>
    </a>
</div>

<div class="ms-card">
    <h3 style="font-size:1rem;font-weight:600;margin-bottom:8px;">Quick start</h3>
    <p class="text-muted mb-0" style="font-size:0.92rem;">
        Use the sidebar to navigate between Patients, Appointments, Prescriptions, and Reports.
        Administrator Settings is available for users with the Administrator role.
    </p>
</div>
