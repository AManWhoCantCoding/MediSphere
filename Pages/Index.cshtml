@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="ms-hero">
    <h1>MediSphere — Hospital Management System</h1>
    <p>A modern hospital management platform built with your clinic's future in mind. Streamline patients, appointments, prescriptions, and reports in one place.</p>
    <a asp-page="/Account/Login" class="btn btn-primary btn-lg px-4">
        <i class="bi bi-box-arrow-in-right me-2"></i>Sign in to get started
    </a>
    <div class="ms-hero-image mt-5">
        <img src="~/resources/Doctor.png" alt="Healthcare professionals">
    </div>
</div>
