@page
@model MediSphere.Pages.Reports.ReportGeneratorModel
@{
    ViewData["Title"] = Localizer["GenerateReport_Title"].Value;
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<h1>@ViewData["Title"]</h1>

<div class="container">
    <div asp-validation-summary="All" class="text-danger"></div>
    <form method="post">
        <div class="form-group">
            <label asp-for="ReportTypeName">@Localizer["ReportTypeLabel"]</label>
            <input asp-for="ReportTypeName" class="form-control" list="reportTypeTemplates" id="reportTypeInput" placeholder="@Localizer["ReportTypePlaceholder"]" />
            <datalist id="reportTypeTemplates">
                @if (Model.ReportTypes != null)
                {
                    @foreach (var reportType in Model.ReportTypes)
                    {
                        <option value="@reportType.TemplateType" data-id="@reportType.ReportTypeId"></option>
                    }
                }
            </datalist>
            <input type="hidden" asp-for="SelectedTemplateTypeId" id="selectedTemplateTypeId" />
            <small class="form-text text-muted">@Localizer["ReportTypeHint"]</small>
        </div>

        <div class="form-group">
            <label asp-for="NewReportModel.PatientId">@Localizer["PatientIdLabel"]</label>
            <select asp-for="NewReportModel.PatientId" class="form-control">
                <option value="">@Localizer["SelectPatient"]</option>
                @if (Model.Patients != null)
                {
                    @foreach (var patient in Model.Patients)
                    {
                        <option value="@patient.PatientId">@($"{patient.FirstName} {patient.LastName}")</option>
                    }
                }
            </select>
            <span asp-validation-for="NewReportModel.PatientId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="NewReportModel.ReportDescription">@Localizer["ReportDescription"]:</label>
            <input asp-for="NewReportModel.ReportDescription" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="NewReportModel.InitialStaffName">@Localizer["InitialStaffName"]</label>
            <input asp-for="NewReportModel.InitialStaffName" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="NewReportModel.Status">@Localizer["Status"]</label>
            <select asp-for="NewReportModel.Status" class="form-control">
                <partial name="_ReportStatusOptionsPartial" />
            </select>
        </div>

        <div class="form-group" style="margin-top: 10px;">
            <button type="submit" asp-page-handler="CreateReport" class="btn btn-primary">@Localizer["GenerateReportButton"]</button>
            <button type="submit" asp-page-handler="CreateTemplateType" class="btn btn-secondary">@Localizer["SaveAsTemplate"]</button>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        (function () {
            const reportTypeInput = document.getElementById('reportTypeInput');
            const selectedTemplateTypeId = document.getElementById('selectedTemplateTypeId');
            const descriptionInput = document.getElementById('NewReportModel_ReportDescription');

            function syncTemplateSelection() {
                const value = reportTypeInput?.value?.trim() ?? '';
                let matchedId = '';

                document.querySelectorAll('#reportTypeTemplates option').forEach(function (option) {
                    if (option.value === value) {
                        matchedId = option.dataset.id || '';
                    }
                });

                if (selectedTemplateTypeId) {
                    selectedTemplateTypeId.value = matchedId;
                }
            }

            reportTypeInput?.addEventListener('input', syncTemplateSelection);
            reportTypeInput?.addEventListener('change', function () {
                syncTemplateSelection();
                if (descriptionInput && reportTypeInput.value && !descriptionInput.value) {
                    descriptionInput.value = reportTypeInput.value;
                }
            });

            syncTemplateSelection();
        })();
    </script>
}
