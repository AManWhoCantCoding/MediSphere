@page
@model MediSphere.Pages.Reports.ReportsModel
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="ms-page-header">
    <h2>Reports</h2>
    <p>Search and manage medical reports.</p>
</div>

<div class="ms-card">
    <form class="ms-search" onsubmit="return false;">
        <input id="searchBox" class="form-control" type="search" placeholder="Search reports...">
        <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
    </form>
    <div class="ms-table-wrap">
        <table class="table ms-table">
            <thead>
                <tr>
                    <th>Report ID</th>
                    <th>Patient ID</th>
                    <th>Created On</th>
                    <th>Report Description</th>
                    <th>Report Type</th>
                    <th>Has Report Been Printed?</th>
                    <th>Report Status</th>
                    <th>Report Started By Staff member</th>
                    <th>Last Updated</th>
                    <th>Last Updated By</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="reports-table-body">
                <tr><td colspan="11" class="text-center text-muted py-4">Loading reports via API...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/reports.js" asp-append-version="true"></script>
}
