@page
@model MediSphere.Pages.Reports.UpdateReportModel
@{
    ViewData["Title"] = "Update Report";
    Layout = "~/Pages/Shared/_DashboardLayout.cshtml";
}

<div class="container border" style="padding: 20px">
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <input type="hidden" asp-for="ExistingReportModel.ReportId" />
        <div class="form-group">
            <label asp-for="ExistingReportModel.PatientId">Patient ID:</label>
            <select asp-for="ExistingReportModel.PatientId" class="form-control">
                <option value="">-- Select Patient --</option>
                @if (Model.Patients != null)
                {
                    @foreach (var patient in Model.Patients)
                    {
                        <option value="@patient.PatientId">@($"{patient.FirstName} {patient.LastName}")</option>
                    }
                }
            </select>
            <span asp-validation-for="ExistingReportModel.PatientId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ExistingReportModel.ReportDescription">Report Description:</label>
            <input asp-for="ExistingReportModel.ReportDescription" class="form-control" />
        </div>
        <div class="form-group">
            <label asp-for="ExistingReportModel.InitialStaffName">Initial Staff Name:</label>
            <input asp-for="ExistingReportModel.InitialStaffName" class="form-control" />
        </div>

        <div class="form-group">
            <label asp-for="ExistingReportModel.Status">Status:</label>
            <select asp-for="ExistingReportModel.Status" class="form-control">
                <option value="1 - Created">1 - Created</option>
                <option value="2 - Checking">2 - Checking</option>
                <option value="3 - In Progress">3 - In Progress</option>
                <option value="4 - Completed">4 - Completed</option>
                <option value="5 - Rejected">5 - Rejected</option>
            </select>
        </div>

        <div class="form-group" style="margin-top: 10px;">
            <button type="submit" class="btn btn-primary">Update Report</button>
        </div>

    </form>
</div>